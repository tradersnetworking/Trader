# Server
PORT=4000
NODE_ENV=development
MAIN_DATABASE_URL=file:./prisma/main.db
INVEST_SQLITE_URL=file:./prisma/invest.db
CLIENT_ORIGIN=http://localhost:5173

# Auth
JWT_SECRET=change-this-super-secret-in-production
JWT_EXPIRES=7d

# SMTP (e.g. Gmail with App Password, or any SMTP provider)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM="Akshaya Exim <no-reply@akshayaexim.com>"

# Invest portal (used in notification email links)
INVEST_PORTAL_URL=http://localhost:5173/invest
MATURITY_REMINDER_DAYS=7
MATURITY_JOB_INTERVAL_MS=21600000

# Google OAuth (web client id)
GOOGLE_CLIENT_ID=

# Optional: Google Custom Search — used by web/scripts/fetch-marketplace-images.mjs
# Create at https://programmablesearchengine.google.com/ (Image search enabled)
GOOGLE_CSE_API_KEY=
GOOGLE_CSE_CX=

# Payment gateways (marketplace + deposits)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
CASHFREE_APP_ID=
CASHFREE_SECRET=
PAYU_KEY=
PAYU_SALT=
JUSPAY_API_KEY=
JUSPAY_MERCHANT_ID=
EXIMPE_API_KEY=
UPI_VPA=akshayaexim@okhdfcbank
UPI_PAYEE_NAME=Akshaya Exim Traders

# Payouts (investor withdrawals)
RAZORPAYX_KEY_ID=
RAZORPAYX_KEY_SECRET=
RAZORPAYX_ACCOUNT_NUMBER=
CASHFREE_PAYOUT_CLIENT_ID=
CASHFREE_PAYOUT_CLIENT_SECRET=

