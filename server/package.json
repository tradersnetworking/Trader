{
  "name": "server",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "nodemon --watch src --ext js,json src/index.js",
    "start": "node src/index.js",
    "prisma:generate": "prisma generate --schema prisma/main.prisma && prisma generate --schema prisma/invest.prisma && prisma generate --schema prisma/invest.postgresql.prisma",
    "db:push": "prisma db push --schema prisma/main.prisma && prisma db push --schema prisma/invest.prisma",
    "db:push:postgres": "prisma db push --schema prisma/invest.postgresql.prisma",
    "db:setup": "npm run prisma:generate && npm run db:push",
    "seed": "node src/seed.js",
    "seed:plans": "node src/seed.js --plans-only",
    "backfill-prices": "node scripts/backfill-product-prices.mjs",
    "enrich-marketplace": "node scripts/enrich-marketplace.mjs",
    "sync-images": "node scripts/sync-marketplace-images.mjs",
    "sync-all-images": "node scripts/sync-all-product-images.mjs",
    "curate-images": "node scripts/curate-product-images.mjs",
    "sync:plans:vps": "node scripts/sync-plans-from-vps.mjs",
    "test:kyc-upload": "node --test tests/kyc-upload-security.test.mjs",
    "test:invest-math": "node --test tests/invest-math.test.mjs",
    "test:unit": "node --test tests/kyc-upload-security.test.mjs tests/invest-math.test.mjs"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "@simplewebauthn/server": "^13.3.1",
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "ioredis": "^5.6.1",
    "imapflow": "^1.3.4",
    "jsonwebtoken": "^9.0.2",
    "mailparser": "^3.9.9",
    "multer": "^1.4.5-lts.1",
    "nanoid": "^5.0.9",
    "nodemailer": "^6.9.16",
    "otplib": "^13.4.1",
    "pdfkit": "^0.18.0",
    "prisma": "^5.22.0",
    "sharp": "^0.33.5",
    "tesseract.js": "^7.0.0",
    "web-push": "^3.6.7",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "nodemon": "^3.1.9"
  }
}
