// MAIN DOMAIN DATABASE (akshayaexim.com / .in)
// Marketplace: users, products, categories, RFQ/quotes, orders, payments
generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/main"
}

datasource db {
  provider = "sqlite"
  url      = env("MAIN_DATABASE_URL")
}

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  phone         String?
  phoneCountryCode String? @default("+91")
  passwordHash  String?
  name          String
  // role: SUPERADMIN, ADMIN, STAFF, USER (buyer/seller)
  role          String   @default("USER")
  // accountType: B2B, B2C
  accountType   String   @default("B2C")
  companyName   String?
  gstNumber     String?
  billingAddress String?
  googleId      String?
  isActive      Boolean  @default(true)
  emailVerified Boolean  @default(false)
  resetToken    String?
  resetExpires  DateTime?
  sessionId     String?  // single active login session (one device)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  products      Product[]
  quotes        Quote[]
  orders        Order[]
  invoices      Invoice[]
  tradeKyc      TradeKyc?
  tradePayments TradePayment[]
}

model Category {
  id          String     @id @default(cuid())
  name        String
  slug        String     @unique
  description String?
  image       String?
  parentId    String?
  parent      Category?  @relation("CategoryChildren", fields: [parentId], references: [id])
  children    Category[] @relation("CategoryChildren")
  products    Product[]
  createdAt   DateTime   @default(now())
}

model Product {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  // listingType: EXPORT (available to export) or IMPORT (required to import)
  listingType String   @default("EXPORT")
  // tradeType: B2B, B2C, BOTH
  tradeType   String   @default("BOTH")
  unit        String   @default("kg")
  minOrderQty Float    @default(1)
  basePrice   Float    @default(0)
  currency    String   @default("INR")
  images      String   @default("[]") // JSON array of urls
  origin      String?
  hsCode      String?
  inStock     Boolean  @default(true)
  isActive    Boolean  @default(true)
  categoryId  String?
  category    Category? @relation(fields: [categoryId], references: [id])
  ownerId     String?
  owner       User?     @relation(fields: [ownerId], references: [id])
  quotes      Quote[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Quote {
  id           String   @id @default(cuid())
  // direction: BUY (user requests to buy/import) or SELL (user offers to supply)
  direction    String   @default("BUY")
  productId    String?
  product      Product? @relation(fields: [productId], references: [id])
  productName  String
  quantity     Float
  unit         String   @default("kg")
  targetPrice  Float?
  currency     String   @default("INR")
  message      String?
  contactName  String
  contactEmail String
  contactPhone String?
  company      String?
  // status: PENDING, RESPONDED, ACCEPTED, REJECTED, CLOSED
  status       String   @default("PENDING")
  adminResponse String?
  quotedPrice  Float?
  userId       String?
  user         User?    @relation(fields: [userId], references: [id])
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Order {
  id           String   @id @default(cuid())
  orderNumber  String   @unique
  userId       String?
  user         User?    @relation(fields: [userId], references: [id])
  items        String   @default("[]") // JSON
  totalAmount  Float
  currency     String   @default("INR")
  status       String   @default("PENDING") // PENDING, PAID, SHIPPED, COMPLETED, CANCELLED
  paymentGateway String?
  paymentRef   String?
  paymentStatus String  @default("UNPAID")
  invoices     Invoice[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Invoice {
  id             String    @id @default(cuid())
  invoiceNumber  String    @unique
  userId         String
  user           User      @relation(fields: [userId], references: [id])
  orderId        String?
  order          Order?    @relation(fields: [orderId], references: [id])
  quoteId        String?
  status         String    @default("DRAFT") // DRAFT, ISSUED, PAID, CANCELLED
  billToName     String
  billToCompany  String?
  billToGst      String?
  billToAddress  String?
  billToEmail    String
  items          String    @default("[]") // JSON line items
  subtotal       Float
  taxPct         Float     @default(0)
  taxAmount      Float     @default(0)
  totalAmount    Float
  currency       String    @default("INR")
  notes          String?
  dueDate        DateTime?
  issuedAt       DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

model Setting {
  id    String @id @default(cuid())
  key   String @unique
  value String
}

// KYC for marketplace buyers (purchasers) and suppliers — India vs international fields
model TradeKyc {
  id              String   @id @default(cuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id])
  partnerType     String   @default("BUYER") // BUYER, SUPPLIER, BOTH
  country         String   @default("IN")
  phoneCountryCode String? @default("+91")
  status          String   @default("PENDING") // PENDING, APPROVED, REJECTED
  fullName        String?
  companyName     String?
  phone           String?
  email           String?
  address         String?
  city            String?
  state           String?
  postalCode      String?
  // India
  panNumber       String?
  aadhaarNumber   String?
  gstNumber       String?
  // International
  passportNumber  String?
  taxId           String?
  companyRegNo    String?
  // Banking
  bankName        String?
  bankAccount     String?
  ifscCode        String?
  swiftCode       String?
  // Documents (upload URLs)
  photo           String?
  panDocument     String?
  aadhaarFront    String?
  aadhaarBack     String?
  passportDocument String?
  companyRegDoc   String?
  addressProof    String?
  bankProof       String?
  cancelledCheque String?
  remarks         String?
  verifiedAt      DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// Collect from purchasers / pay suppliers — routed via main-domain gateways
model TradePayment {
  id           String   @id @default(cuid())
  userId       String?
  user         User?    @relation(fields: [userId], references: [id])
  orderId      String?
  direction    String   // COLLECT (from buyer), DISBURSE (to supplier)
  amount       Float
  currency     String   @default("INR")
  method       String   // UPI, BANK, RAZORPAY, etc.
  gateway      String?
  gatewayRef   String?
  reference    String?
  proofImage   String?
  partyName    String?
  partyEmail   String?
  partyPhone   String?
  partyPhoneCountryCode String?
  status       String   @default("PENDING") // PENDING, PAID, REJECTED, PROCESSING
  remarks      String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
