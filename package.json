{
  "name": "akshaya-exim",
  "version": "1.0.0",
  "private": true,
  "description": "Akshaya Exim Traders - Export/Import marketplace + Investor portal",
  "workspaces": [
    "server",
    "web"
  ],
  "scripts": {
    "dev": "concurrently -n server,web -c blue,green \"npm:dev:server\" \"npm:dev:web\"",
    "dev:server": "npm --workspace server run dev",
    "dev:web": "npm --workspace web run dev",
    "setup": "npm --workspace server run db:setup",
    "seed": "npm --workspace server run seed",
    "build": "npm --workspace web run build",
    "smoke:main": "node scripts/smoke-main.mjs",
    "smoke:invest": "node scripts/smoke-invest.mjs",
    "smoke": "node scripts/smoke-main.mjs && node scripts/smoke-invest.mjs",
    "verify:local": "node scripts/local-verify.mjs",
    "audit": "node scripts/portal-audit.mjs",
    "audit:prod": "node scripts/production-audit.mjs",
    "audit:workflow": "node scripts/api-workflow-audit.mjs",
    "audit:dashboard": "node scripts/dashboard-api-audit.mjs",
    "audit:full": "node scripts/run-full-audit.mjs",
    "audit:discovery": "node scripts/generate-platform-discovery.mjs",
    "audit:security-headers": "node scripts/security-headers-audit.mjs",
    "audit:load": "node scripts/load-test-invest.mjs",
    "e2e:fixture": "npm --workspace server exec -- node ../scripts/generate-e2e-kyc-fixture.mjs",
    "test:e2e:prod": "npm run e2e:fixture && node scripts/run-e2e-prod.mjs",
    "test:e2e:admin": "node scripts/run-e2e-admin.mjs",
    "test:unit": "npm run test:unit --workspace server",
    "seo:submit": "node scripts/main-seo-submit.mjs",
    "enrich-marketplace": "npm run enrich-marketplace --workspace server",
    "fetch-product-images": "npm run fetch-images --workspace web",
    "sync-images": "npm run sync-images --workspace server",
    "sync-all-images": "npm run sync-all-images --workspace server",
    "curate-images": "npm run curate-images --workspace server",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "concurrently": "^9.1.0"
  }
}
