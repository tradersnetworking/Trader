NODE_ENV=production
PORT=4000

# SQLite paths (local dev: relative to server/; Docker sets file:/data/*.db)
MAIN_DATABASE_URL=file:./prisma/main.db
INVEST_SQLITE_URL=file:./prisma/invest.db

# Public URLs (used in emails, redirects, CORS)
CLIENT_ORIGIN=https://akshayaexim.com
MAIN_ORIGIN=https://akshayaexim.com
INVEST_ORIGIN=https://invest.akshayaexim.com
INVEST_PORTAL_URL=https://invest.akshayaexim.com
# Payment gateway return URLs & webhooks — always main domain (not invest subdomain)
PAYMENT_ORIGIN=https://akshayaexim.com

# Optional: protect POST /api/main/public/seo/submit-indexing from the public internet
# MAIN_SEO_SUBMIT_SECRET=long-random-string

JWT_SECRET=CHANGE_ME_LONG_RANDOM_SECRET
JWT_EXPIRES=7d
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=noreply@akshayaexim.com
SMTP_PASS=
IMAP_HOST=imap.hostinger.com
MAIN_MAILBOX_SMTP_PASS=
INVEST_MAILBOX_SMTP_PASS=
MAIL_FROM=Akshaya ExIm <noreply@akshayaexim.com>
# Set false to skip email OTP on login when SMTP is not ready (recommended on VPS until mail is configured)
# LOGIN_OTP_REQUIRED=false

# Optional: custom invest marketing domain (configure in Admin → Site & API Settings)
# INVEST_ADDITIONAL_DOMAIN=akshayainvest.com
GOOGLE_CLIENT_ID=
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
CASHFREE_APP_ID=
CASHFREE_SECRET_KEY=
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
PAYGLOCAL_MERCHANT_ID=
PAYGLOCAL_API_KEY=
XFLOWPAY_MERCHANT_ID=
XFLOWPAY_API_KEY=
PINLABS_CLIENT_ID=
PINLABS_CLIENT_SECRET=
PINLABS_API_BASE=https://api.pluralpay.in

# PostgreSQL (production — see deploy/postgres-migration.md)
# INVEST_DATABASE_URL=postgresql://akshaya:PASSWORD@postgres:5432/akshaya_invest
# POSTGRES_PASSWORD=PASSWORD

# Main marketplace: IndiaMART / TradeIndia images & indicative prices (Google Custom Search)
# GOOGLE_CSE_API_KEY=
# GOOGLE_CSE_CX=
# MARKETPLACE_CRON_SECRET=long-random-string
# MARKETPLACE_SYNC_INTERVAL_MS=43200000
# MARKETPLACE_SYNC_BATCH=25
# MARKETPLACE_BOOTSTRAP_ON_START=true
# MARKETPLACE_BOOTSTRAP_DELAY_MS=45000

# Super-admin Platform Update (one-click git pull + Docker rebuild on VPS)
# PLATFORM_DEPLOY_ENABLED=true
# HOST_REPO_PATH=/opt/akshaya-exim
# PLATFORM_DEPLOY_BRANCH=main
# PLATFORM_DEPLOY_GITHUB_URL=https://github.com/tradersnetworking/Trader.git
# Uncomment host repo + docker.sock volumes in deploy/docker-compose.yml when enabling

# Redis (Docker Compose provides redis://redis:6379 by default)
# REDIS_URL=redis://redis:6379

# KYC virus scan (clamscan installed in API image)
# KYC_VIRUS_SCAN_CMD=clamscan --no-summary {file}
# KYC_UPLOAD_RATE_MAX=60

# E2E / CI probes (never commit real passwords — set only in deploy/.env on VPS)
# E2E_INVESTOR_EMAIL=investor@akshayaexim.com
# E2E_INVESTOR_PASSWORD=
# E2E_ADMIN_EMAIL=superadmin@akshayaexim.com
# E2E_ADMIN_PASSWORD=
