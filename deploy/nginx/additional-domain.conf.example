# Additional invest domain — e.g. akshayainvest.com
# Copy to /etc/nginx/sites-available/ and symlink to sites-enabled.
# DNS: A record → your VPS IP (same as invest.akshayaexim.com)

upstream akshaya_api {
    server 127.0.0.1:4000;
    keepalive 32;
}

server {
    listen 80;
    listen [::]:80;
    server_name akshayainvest.com www.akshayainvest.com;
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name akshayainvest.com www.akshayainvest.com;

    ssl_certificate     /etc/letsencrypt/live/akshayainvest.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/akshayainvest.com/privkey.pem;

    client_max_body_size 12m;
    gzip on;
    gzip_vary on;
    gzip_min_length 256;
    gzip_types text/plain text/css application/json application/javascript text/xml application/xml image/svg+xml;

    # Payments must NOT be initiated on this host — app routes gateways to akshayaexim.com only.

    location ~* ^/assets/.+\.[a-f0-9]{8,}\.(js|css|woff2?|png|jpg|webp|svg)$ {
        proxy_pass http://akshaya_api;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        add_header Cache-Control "public, max-age=31536000, immutable";
    }

    location /api/ {
        proxy_pass http://akshaya_api;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    location /uploads/ {
        proxy_pass http://akshaya_api;
        proxy_set_header Host $host;
    }

    location / {
        proxy_pass http://akshaya_api;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }
}
